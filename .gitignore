# ==========================================
# 1. VIRTUAL ENVIRONMENT (Never push dependencies)
# ==========================================
venv/
env/
ENV/

# ==========================================
# 2. ENVIRONMENT VARIABLES (CRITICAL: Protects your API Keys)
# ==========================================
.env
.env.local

# ==========================================
# 3. PYTHON CACHE & COMPILED FILES
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 4. IDE & EDITOR SETTINGS
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# 5. OS GENERATED FILES
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# 6. STREAMLIT SPECIFIC
# ==========================================
.streamlit/secrets.toml

# ==========================================
# 7. PROJECT SPECIFIC / TEMPORARY FILES
# ==========================================
*.zip
output.png